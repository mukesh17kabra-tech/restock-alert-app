generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// One row per Shopify store that installs the app
model Shop {
  id          String   @id @default(cuid())
  shopDomain  String   @unique // e.g. my-store.myshopify.com
  accessToken String
  plan        String   @default("free") // free | pro
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // WhatsApp connection via Twilio (one Twilio account, owned by you —
  // each merchant onboards their own number through a Twilio-hosted
  // embedded signup link, no Twilio/Meta account needed on their end).
  twilioSenderSid       String?   // e.g. "XExxxxxxxx", identifies this merchant's registered sender
  whatsappNumber        String?   // e.g. "+91XXXXXXXXXX", the merchant's connected WhatsApp number
  whatsappSenderStatus  String?   // "pending" | "online" | "rejected" etc, mirrors Twilio's status
  whatsappConnectedAt   DateTime?

  // Merchant toggle: which channels the storefront popup collects/sends.
  // "email" | "whatsapp" | "both"
  notifyChannels String @default("email")

  // Tracks the active Shopify recurring charge so Business-tier overage can
  // be billed against it via the Usage Charge API.
  recurringChargeId String?

  // Monthly WhatsApp usage counter — reset by the billing-cycle cron.
  // Kept simple (not per-conversation) since template messages are what
  // this app sends, and Meta bills per-message in that category.
  whatsappMessagesThisCycle Int      @default(0)
  currentCycleStartedAt     DateTime @default(now())

  // When true, ignores plan caps (signup cap + WhatsApp cap) for this shop.
  // For your own testing only — toggle manually in the database, no UI
  // exposes this to merchants.
  testModeBypassCaps Boolean @default(false)

  subscribers VariantSubscriber[]
  webhookLogs WebhookLog[]
}

// A customer waiting on a specific out-of-stock variant
model VariantSubscriber {
  id          String    @id @default(cuid())
  shopId      String
  shop        Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)

  productId   String    // Shopify product GID
  variantId   String    // Shopify variant GID
  productTitle String
  variantTitle String
  email       String?
  phone       String?   // E.164 format, e.g. +91XXXXXXXXXX
  name        String?

  notified    Boolean   @default(false)
  notifiedAt  DateTime?
  reminderSent Boolean  @default(false)
  createdAt   DateTime  @default(now())

  @@index([shopId, variantId])
}

// Raw log of inventory webhooks received, for debugging/audit
model WebhookLog {
  id        String   @id @default(cuid())
  shopId    String
  shop      Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  topic     String
  payload   Json
  createdAt DateTime @default(now())
}
